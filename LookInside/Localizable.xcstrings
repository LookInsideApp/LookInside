    "You can click \"Pause\" button near the bottom-left corner in Xcode to pause your iOS app, and input in Xcode console like the contents below:\nexpr [((%@ *)%@) %@]" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can click \"Pause\" button near the bottom-left corner in Xcode to pause your iOS app, and input in Xcode console like the contents below:\nexpr [((%1$@ *)%2$@) %3$@]"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你可以点击 Xcode 左下角附近的“Pause”按钮，让 iOS App 暂停，然后在 Xcode 控制台中输入如下内容：\nexpr [((%1$@ *)%2$@) %3$@]"
          }
        }
      }
    },
